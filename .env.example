DISCORD_TOKEN=your_bot_token_here

# One or more channels (comma-separated), any server the bot is on
DISCORD_CHANNEL_IDS=123456789012345678

# Lobby name substring (map version suffixes like +64 are ignored)
NAME_FILTER=ZemliBoga Re-Stored

# Host creator ID on IrInA (creatorUserId from API)
CREATOR_USER_ID=248324

# Optional extra filter; leave empty when map versions change often
# MAP_ID=73706

# Poll every N seconds (minimum 1)
POLL_INTERVAL_SEC=1
